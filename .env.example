ANTHROPIC_API_KEY=your_anthropic_api_key_here
ADZUNA_APP_ID=your_adzuna_app_id_here
ADZUNA_APP_KEY=your_adzuna_app_key_here

# Local development (SQLite)
DATABASE_URL=sqlite+aiosqlite:///./applications.db

# Cloud deployment — Railway auto-sets DATABASE_URL when you add a Postgres plugin.
# Render: set to sqlite+aiosqlite:////data/applications.db (uses the /data persistent disk)
# DATABASE_URL=postgresql+asyncpg://user:password@host:5432/dbname
